FROM python:3.11-slim

RUN pip install --no-cache-dir \
    matplotlib \
    numpy \
    pandas \
    networkx \
    pyyaml \
    requests \
    beautifulsoup4 \
    lxml \
    pillow \
    scikit-learn \
    scipy \
    seaborn \
    tabulate \
    jsonlines \
    && rm -rf /root/.cache

# Tools for file analysis
RUN apt-get update && apt-get install -y --no-install-recommends \
    file \
    hexdump \
    xxd \
    jq \
    tree \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
