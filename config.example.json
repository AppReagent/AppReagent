{
    // AppReagent config — line (//) and block (/* */) comments are supported.
    "postgres_url": "postgresql://user:password@host:port/dbname",
    "postgres_cert": "ca-certificate.crt",
    "ai_endpoints": [
        // Tier 0 — cheap and fast (triage / supervisors).
        {
            "id": "local-ollama",
            "provider": "ollama",
            "url": "http://192.0.2.10:11434",
            "model": "qwen2.5-coder:7b",
            "tier": 0,
            "max_concurrent": 1,
            "context_window": 32768
        },
        {
            "id": "local-lmstudio",
            "provider": "lmstudio",
            "url": "http://192.0.2.11:1234",
            "model": "qwen2.5-coder-7b-instruct",
            "tier": 0,
            "max_concurrent": 1
        },
        // Tier 1 — medium (deep analysis supervisor).
        {
            "id": "mid-tier",
            "provider": "ollama",
            "url": "http://192.0.2.20:11434",
            "model": "qwen2.5-coder:14b",
            "tier": 1,
            "max_concurrent": 2
        },
        // Tier 2 — expensive and smart (deep analysis worker, synthesis).
        {
            "id": "gpu-host",
            "provider": "lmstudio",
            "url": "http://192.0.2.30:1234",
            "model": "glm-4.7-flash",
            "tier": 2,
            "max_concurrent": 3
        }
        /*
        ,{
            "id": "openai-gpt4o",
            "provider": "openai",
            "url": "https://api.openai.com",
            "model": "gpt-4o",
            "api_key": "sk-...",
            "tier": 2,
            "max_concurrent": 5,
            "context_window": 128000
        }
        */
    ],
    // RAG backend — pick one:
    //
    // (a) Managed RAG via Vultr serverless inference: Vultr hosts the
    //     embedding model and the vector store. Requires a collection
    //     created via POST /v1/vector_store.
    "embedding": {
        "provider": "vultr",
        "url": "https://api.vultrinference.com",
        "api_key": "...",
        "collection_id": "appreagent"
    },
    // (b) Custom RAG — your own embedding model (OpenAI / Ollama / LM Studio)
    //     plus a local pgvector table. Replace the block above with this
    //     if you'd rather bring your own embeddings.
    /*
    "embedding": {
        "provider": "openai",
        "url": "https://api.openai.com",
        "model": "text-embedding-3-small",
        "api_key": "sk-...",
        "dimensions": 1536
    },
    */
    "job_batch_size": 10,
    "flush_timeout_sec": 15,
    "theme": "dark"
}
