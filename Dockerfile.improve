FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Build dependencies for area + eval tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake \
    libpq-dev libcurl4-openssl-dev libssl-dev \
    git curl ca-certificates gnupg \
    jq bc postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22.x (for Claude Code and Codex)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install the selected coding agent
ARG AGENT=claude
RUN if [ "$AGENT" = "claude" ]; then \
        npm install -g @anthropic-ai/claude-code; \
    elif [ "$AGENT" = "codex" ]; then \
        npm install -g @openai/codex; \
    elif [ "$AGENT" = "opencode" ]; then \
        ARCH=$(dpkg --print-architecture) && \
        curl -fsSL "https://github.com/opencode-ai/opencode/releases/latest/download/opencode_linux_${ARCH}" \
            -o /usr/local/bin/opencode && chmod +x /usr/local/bin/opencode; \
    else \
        echo "Unknown agent: $AGENT" && exit 1; \
    fi

# Non-root user matching host UID (replace default ubuntu user if present)
ARG UID=1000
ARG GID=1000
RUN userdel -r ubuntu 2>/dev/null || true \
    && groupadd -g $GID builder 2>/dev/null || true \
    && useradd -m -u $UID -g $GID -s /bin/bash builder
USER builder

RUN git config --global user.name "area-improve" \
    && git config --global user.email "improve@area" \
    && git config --global --add safe.directory /workspace

WORKDIR /workspace

COPY --chmod=755 scripts/agent-entrypoint.sh /usr/local/bin/agent-entrypoint.sh

# Copy the full source tree into the image
COPY --chown=builder:builder . /workspace

ENV AGENT=${AGENT}

ENTRYPOINT ["/usr/local/bin/agent-entrypoint.sh"]
